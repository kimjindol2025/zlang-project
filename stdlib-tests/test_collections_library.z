// Z-Lang Standard Library Test Suite: Collections Functions

fn array_sum(a: i64, b: i64, c: i64) -> i64 {
    return a + b + c;
}

fn array_max(a: i64, b: i64, c: i64) -> i64 {
    let max_val: i64 = a;

    if b > max_val {
        max_val = b;
    }

    if c > max_val {
        max_val = c;
    }

    return max_val;
}

fn array_min(a: i64, b: i64, c: i64) -> i64 {
    let min_val: i64 = a;

    if b < min_val {
        min_val = b;
    }

    if c < min_val {
        min_val = c;
    }

    return min_val;
}

fn array_avg(a: i64, b: i64, c: i64) -> i64 {
    return (a + b + c) / 3;
}

fn array_contains(target: i64, a: i64, b: i64, c: i64) -> bool {
    if a == target {
        return true;
    }

    if b == target {
        return true;
    }

    if c == target {
        return true;
    }

    return false;
}

fn array_filter_even(a: i64, b: i64, c: i64) -> i64 {
    let count: i64 = 0;

    if (a % 2) == 0 {
        count = count + 1;
    }

    if (b % 2) == 0 {
        count = count + 1;
    }

    if (c % 2) == 0 {
        count = count + 1;
    }

    return count;
}

fn main() {
    let test_count: i64 = 0;
    let pass_count: i64 = 0;

    // Test 1: array_sum(10, 20, 30) == 60
    test_count = test_count + 1;
    if array_sum(10, 20, 30) == 60 {
        pass_count = pass_count + 1;
        println(49);
    }

    // Test 2: array_sum(5, 5, 5) == 15
    test_count = test_count + 1;
    if array_sum(5, 5, 5) == 15 {
        pass_count = pass_count + 1;
        println(49);
    }

    // Test 3: array_max(10, 50, 30) == 50
    test_count = test_count + 1;
    if array_max(10, 50, 30) == 50 {
        pass_count = pass_count + 1;
        println(49);
    }

    // Test 4: array_min(10, 50, 30) == 10
    test_count = test_count + 1;
    if array_min(10, 50, 30) == 10 {
        pass_count = pass_count + 1;
        println(49);
    }

    // Test 5: array_avg(10, 20, 30) == 20
    test_count = test_count + 1;
    if array_avg(10, 20, 30) == 20 {
        pass_count = pass_count + 1;
        println(49);
    }

    // Test 6: array_contains(20, 10, 20, 30) == true
    test_count = test_count + 1;
    if array_contains(20, 10, 20, 30) == true {
        pass_count = pass_count + 1;
        println(49);
    }

    // Test 7: array_contains(99, 10, 20, 30) == false
    test_count = test_count + 1;
    if array_contains(99, 10, 20, 30) == false {
        pass_count = pass_count + 1;
        println(49);
    }

    // Test 8: array_filter_even(10, 15, 20) == 2
    test_count = test_count + 1;
    if array_filter_even(10, 15, 20) == 2 {
        pass_count = pass_count + 1;
        println(49);
    }

    // Test 9: array_filter_even(1, 3, 5) == 0
    test_count = test_count + 1;
    if array_filter_even(1, 3, 5) == 0 {
        pass_count = pass_count + 1;
        println(49);
    }

    // Print summary
    println(84);  // "T" for Total
    println(test_count);
    println(80);  // "P" for Passed
    println(pass_count);

    return;
}
